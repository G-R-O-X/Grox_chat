# Placeholder only. Put your real MiniMax key in local .env, never in git.
MINIMAX_API_KEY=your_minimax_api_key_here
# 0 = mainland endpoint api.minimaxi.com (default), 1 = international endpoint api.minimax.io
MINIMAX_EN=0
# 0 = disable Gemini entirely, 1 = allow Gemini orchestration/runtime calls
ENABLE_GEMINI=0
# 0 = strictly sequential debate (default), 1 = enable Fast Mode (concurrent Round 1 & parallel special interventions)
FAST_MODE=0
